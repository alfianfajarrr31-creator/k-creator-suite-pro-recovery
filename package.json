{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "2.10.0",
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-react": "5.2.0",
    "lucide-react": "0.546.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "6.4.3",
    "express": "4.22.2",
    "dotenv": "17.4.2",
    "motion": "12.42.2",
    "@supabase/supabase-js": "2.110.0"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "autoprefixer": "10.5.2",
    "esbuild": "0.25.12",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "5.8.3",
    "vite": "6.4.3",
    "@types/express": "4.17.25"
  },
  "engines": {
    "node": "24.x"
  }
